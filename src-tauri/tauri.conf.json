{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Figmaboy",
  "version": "0.1.0",
  "identifier": "com.miki.figmaboy",
  "build": {
    "beforeDevCommand": "bun run sidecar:prepare:dev && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run sidecar:prepare && bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Figmaboy",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "incognito": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/figmaboy-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
