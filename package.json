{
  "name": "figmaboy",
  "version": "0.1.0",
  "description": "A local-first desktop interface design tool",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "sidecar:prepare": "bun scripts/prepare-sidecar.mjs",
    "sidecar:prepare:dev": "bun scripts/prepare-sidecar.mjs --debug",
    "sidecar:smoke": "bun scripts/smoke-sidecar.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@iconify-json/lucide": "^1.2.116",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "immer": "^11.1.11",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
